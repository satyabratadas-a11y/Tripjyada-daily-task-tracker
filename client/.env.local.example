# local dev: leave blank — next.config.mjs proxies /api/* to the local server (works from
# localhost or a LAN IP, e.g. for testing camera features on a phone, without cookie issues)
# production: your deployed API origin (e.g. https://task-tracker-api.onrender.com), no trailing slash
NEXT_PUBLIC_API_URL=

# optional: enables the Google sign-in button on the login page
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
